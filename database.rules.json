{
  "rules": {
    "clubs": {
      "admins": {
        ".read": "auth != null && root.child('clubs/admins').hasChild(auth.uid)",
        ".write": "auth != null && root.child('clubs/admins').hasChild(auth.uid)"
      },
      "directory": {
        ".indexOn": ["name", "is_active"],
        ".read": true,
        ".write": "auth != null && root.child('clubs/admins').hasChild(auth.uid)"
      },
      "unpublished": {
        ".read": "auth != null",
        "$clubId": {
          ".write": "auth != null && ((root.child('clubs/admins').hasChild(auth.uid)) || ((data.exists() && (data.child('leader').hasChild(auth.uid) || data.child('advisor').hasChild(auth.uid))) || (!data.exists() && (newData.child('leader').hasChild(auth.uid) || newData.child('advisor').hasChild(auth.uid)))))"
        }
      },
      "members": {
        "$clubId": {
          ".read": "auth != null && (root.child('clubs/members').child($clubId).hasChild(auth.uid) || root.child('clubs/directory').child($clubId).child('leader').hasChild(auth.uid) || root.child('clubs/directory').child($clubId).child('advisor').hasChild(auth.uid) || root.child('clubs/admins').hasChild(auth.uid))",
          "$uid": {
            ".write": "auth != null && ((auth.uid === $uid && root.child('clubs/directory').child($clubId).exists() && (!newData.exists() || root.child('clubs/directory').child($clubId).child('join_policy').val() !== 'approval')) || root.child('clubs/directory').child($clubId).child('leader').hasChild(auth.uid) || root.child('clubs/directory').child($clubId).child('advisor').hasChild(auth.uid) || root.child('clubs/admins').hasChild(auth.uid))",
            ".validate": "!newData.exists() || newData.hasChildren(['name', 'email', 'joinedAt'])"
          }
        }
      },
      "join_requests": {
        "$clubId": {
          ".read": "auth != null && (root.child('clubs/directory').child($clubId).child('leader').hasChild(auth.uid) || root.child('clubs/directory').child($clubId).child('advisor').hasChild(auth.uid) || root.child('clubs/admins').hasChild(auth.uid))",
          "$uid": {
            ".read": "auth != null && auth.uid === $uid",
            ".write": "auth != null && (auth.uid === $uid || root.child('clubs/directory').child($clubId).child('leader').hasChild(auth.uid) || root.child('clubs/directory').child($clubId).child('advisor').hasChild(auth.uid) || root.child('clubs/admins').hasChild(auth.uid))",
            ".validate": "!newData.exists() || newData.hasChildren(['name', 'email', 'requestedAt'])"
          }
        }
      }
    },
    "events": {
      ".read": true,
      ".indexOn": ["clubId", "start"],
      "$eventId": {
        ".write": "auth != null && (root.child('clubs/admins').hasChild(auth.uid) || ((!newData.exists() || root.child('clubs/directory').child(newData.child('clubId').val()).child('leader').hasChild(auth.uid) || root.child('clubs/directory').child(newData.child('clubId').val()).child('advisor').hasChild(auth.uid)) && (!data.exists() || root.child('clubs/directory').child(data.child('clubId').val()).child('leader').hasChild(auth.uid) || root.child('clubs/directory').child(data.child('clubId').val()).child('advisor').hasChild(auth.uid))))",
        ".validate": "!newData.exists() || newData.hasChildren(['title', 'clubId', 'start'])"
      }
    },
    "global": {
      ".read": true,
      ".write": true
    },
    "last_updated": {
      ".read": true,
      ".write": false
    },
    "leaderboards": {
      "$leaderboard": {
        ".read": true,
        ".indexOn": "s",
        "$uid": {
          ".write": "$uid === auth.uid && (!data.exists() || newData.child('s').val() >= data.child('s').val())"
        }
      }
    },
    "metadata": {
      ".read": true,
      ".write": false
    },
    "tag_game": {
      ".read": true,
      ".write": true
    },
    "users": {
      "public": {
        ".read": "auth != null",
        ".indexOn": ["email"],
        "$uid": {
          ".write": "auth != null && (auth.uid === $uid || root.child('clubs/admins').hasChild(auth.uid))",
          "clubs": {
            "$clubId": {
              ".write": "auth != null && (root.child('clubs/directory').child($clubId).child('leader').hasChild(auth.uid) || root.child('clubs/directory').child($clubId).child('advisor').hasChild(auth.uid))"
            }
          }
        }
      },
      "private": {
        "$uid": {
          ".read": "$uid === auth.uid",
          "kiosks": {
            ".write": "$uid === auth.uid"
          },
          "is_club_admin": {
            ".write": false
          }
        }
      }
    }
  }
}
